# Backend do Run4BrasilAfrica (Google Apps Script). Veja apps-script/README.md.
# Copie este arquivo para .env.local e preencha os valores da sua implantação.

# URL do App da Web do Apps Script (termina em /exec).
GAS_WEB_APP_URL=

# Token de escrita — DEVE ser igual à propriedade de script SHARED_TOKEN no GAS.
# Fica só no servidor (nunca é enviado ao navegador).
GAS_SHARED_TOKEN=
